{
  "name": "obolus",
  "version": "0.0.0",
  "description": "Observability for AI coding-agent spend — see what each PR, repo, and developer actually costs.",
  "type": "module",
  "license": "MIT",
  "author": "Aporyn",
  "homepage": "https://obolus.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/obolus/obolus.git"
  },
  "bugs": {
    "url": "https://github.com/obolus/obolus/issues"
  },
  "keywords": [
    "ai",
    "llm",
    "cost",
    "observability",
    "finops",
    "tokens",
    "claude-code",
    "coding-agent",
    "cli"
  ],
  "bin": {
    "obolus": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.0"
  }
}
